<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

  <PropertyGroup>
	<OutputType>WinExe</OutputType>
	<TargetFramework>net10.0-windows</TargetFramework>
	<UseWindowsForms>true</UseWindowsForms>
	<AssemblyName>YouTubeVideoPlayer</AssemblyName>
	<RootNamespace>YouTubeVideoPlayer</RootNamespace>
	<Platforms>AnyCPU;x64</Platforms>
	<AssemblyVersion>1.0.1</AssemblyVersion>
	<FileVersion>1.0.1</FileVersion>
  </PropertyGroup>

  <ItemGroup>
	<PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
	<PackageReference Include="LibVLCSharp" Version="3.6.7" />
	<PackageReference Include="LibVLCSharp.WinForms" Version="3.6.7" />
	<PackageReference Include="YoutubeExplode" Version="6.6.0" />
	<PackageReference Include="VideoLAN.LibVLC.Windows" Version="3.0.18" />
  </ItemGroup>

  <ItemGroup>
    <None Update="videos.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
